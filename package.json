{
  "name": "@velnora/monorepo",
  "version": "0.0.0-dev.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "libs/*",
    "libs/**/*",
    "examples/*",
    "docs"
  ],
  "scripts": {
    "affected:build": "nx affected -t build",
    "affected:lint": "nx affected -t lint",
    "affected:test": "nx affected -t test",
    "build": "nx run velnora:build",
    "changeset:publish": "changeset publish",
    "changeset:version": "changeset version",
    "check:libs:deps": "./scripts/check-libs-deps.sh",
    "dev": "nx run hello-mfe-shell:dev",
    "lint": "nx run-many -t lint",
    "lint:all": "eslint . --ext .ts,.tsx,.js,.jsx",
    "prepare": "nx run-many -t build",
    "test": "vitest --config vitest.config.ts",
    "test:coverage": "vitest --config vitest.config.ts --coverage",
    "typecheck": "nx run-many -t typecheck"
  },
  "resolutions": {
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@nx/devkit": "22.7.1",
    "@velnora/internal": "workspace:^"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@nx/eslint-plugin": "^22.7.1",
    "@nx/jest": "22.7.1",
    "@nx/js": "22.7.1",
    "@nx/plugin": "22.7.1",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.1",
    "@swc/core": "~1.15.33",
    "@swc/helpers": "~0.5.21",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "depcheck": "^1.4.7",
    "eslint": "^10.3.0",
    "nx": "^22.7.1",
    "prettier": "^3.8.3",
    "prettier-plugin-packagejson": "^3.0.2",
    "tslib": "^2.8.1",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite-node": "^6.0.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  },
  "packageManager": "yarn@4.12.0",
  "engines": {
    "node": ">=22"
  }
}
